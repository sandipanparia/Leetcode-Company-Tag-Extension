{
  "manifest_version": 3,
  "name": "LeetCode Company Tag Viewer",
  "version": "1.3",
  "description": "Displays problem difficulty, company tags, and frequency on LeetCode problem pages.",
  "permissions": ["storage", "favicon"],
  "host_permissions": ["*://leetcode.com/problems/*", "https://*.google.com/*", "https://*.gstatic.com/*", "https://logo.clearbit.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/problems/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data.json", 
        "icon16.png",
        "icon32.png",
        "icon48.png",
        "icon128.png",
        "logo_amazon.png",
        "logo_google.png",
        "logo_meta.png",
        "logo_microsoft.png"
      ],
      "matches": ["*://leetcode.com/*"]
    },
    {
      "resources": ["_favicon/*"],
      "matches": ["*://leetcode.com/*"],
      "extension_ids": ["*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetCode Company Tag Viewer",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}